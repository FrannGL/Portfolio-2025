---
import Header from "@/components/custom/Header.astro";
import { t } from "@/i18n";

export interface Props {
  lang?: string;
}

const { lang = "es" } = Astro.props;

const cards = [
  { key: "ui", src: "/assets/logo_notimation.png", alt: "Notimation", text: "Notimation" },
  { key: "web", src: "/assets/jst.png", alt: "JST Seguridad en el Transporte", text: "JST | Seguridad en el Transporte" },
  { key: "seo", src: "/assets/finanex.png", alt: "Finanex", text: "Finanex" },
  { key: "fit", src: "/assets/fit.png", alt: "Fit", text: "Fit" },
  { key: "nefra", src: "/assets/nefra.png", alt: "Nefra", text: "Nefra" },
  { key: "zerobug", src: "/assets/zerobug.png", alt: "Zerobug", text: "Zerobug" },
];
---

<div class="flex flex-col items-center justify-center pb-6.5 pt-5 gap-1 text-foreground">
  <Header title={t(lang, "clients.title")} subtitle={t(lang, "clients.subtitle")} icon="ion:rocket-sharp" />

  <div class="mt-4 w-full overflow-hidden">
    <div class="flex w-fit gap-4 animate-[scroll-carousel-right_20s_linear_infinite]">
      {Array.from({ length: 2 }).flatMap((_, i) =>
        cards.map(({ key: cardKey, src, alt }) => (
          <div
            class="flex flex-col items-center justify-center w-48 xl:w-40 h-12.5 xl:h-10.5 bg-[#191919] text-white rounded-lg shadow-sm border border-[#212121] mx-2 p-1 shrink-0"
          >
            <img src={src} alt={alt} class="max-h-full object-contain" />
          </div>
        ))
      )}
    </div>
  </div>
</div>
